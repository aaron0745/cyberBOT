# cyberBOT: Environment Configuration Template
# Rename this file to .env and fill in your actual credentials.

# 1. Your Discord Bot Token (Get this from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# 2. Your Server (Guild) ID (Right-click your server icon in Discord -> Copy Server ID)
# Enabling this allows instant /command updates for your server.
GUILD_ID=your_server_id_here
